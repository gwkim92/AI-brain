NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# store backend: auto|memory|postgres
STORE_BACKEND=auto
DATABASE_URL=postgres://jarvis:jarvis@localhost:5432/jarvis

DEFAULT_USER_ID=00000000-0000-4000-8000-000000000001
DEFAULT_USER_EMAIL=jarvis-local@example.com

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW_SEC=60

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_WEBHOOK_SECRET=

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-pro

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-7-sonnet-latest

LOCAL_LLM_ENABLED=true
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_LLM_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
